# GIN 模式（debug, test, release）
GIN_MODE=debug
# CORS origins（逗號分隔）
ORIGIN_URL=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_PRIVATE=100

# 微服務連接設定 (URLs & Ports)
GATEWAY_PORT=8100
ORDER_SERVICE_PORT=8101
MARKET_DATA_PORT=8102
MATCHING_ENGINE_PORT=8103
SIMULATION_SERVICE_PORT=8104

# 微服務URL設定
GATEWAY_URL=http://gateway:8100
ORDER_SERVICE_URL=http://order-service:8101
MARKET_DATA_SERVICE_URL=http://market-data-service:8102
SIMULATION_SERVICE_URL=http://simulation-service:8104

# 資料庫連接設定
DATABASE_URL=postgres://user:password@localhost:5432/exchange?sslmode=disable

# Redis 連接設定
REDIS_URL=redis://:password@localhost:6379/0

# Kafka 連接設定
KAFKA_BROKERS=localhost:9092
KAFKA_ALLOW_AUTO_CREATE=false
KAFKA_RESET_OFFSET=latest
