GO_ENV=development
ORDER_SERVICE_PORT=8080
MATCHING_ENGINE_PORT=8081

# 微服務連接設定 (URLs & Ports)
GATEWAY_PORT=8084
MARKET_DATA_PORT=8083
ORDER_SERVICE_URL=http://order-service:8080
MARKET_DATA_SERVICE_URL=http://market-data-service:8083

# 資料庫連接設定
DATABASE_URL=postgres://user:password@localhost:5432/exchange?sslmode=disable

# Redis 連接設定
REDIS_URL=redis://:password@localhost:6379/0

# Kafka 連接設定
KAFKA_BROKERS=localhost:9092
KAFKA_CONNECT_TIMEOUT=5s
KAFKA_ALLOW_AUTO_CREATE=false
