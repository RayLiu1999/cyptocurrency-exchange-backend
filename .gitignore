## -----------------------------
# Ignore rules for backend
## -----------------------------

# --- Binaries and build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
/server
*.test
*.prof
*.test
*.out
coverage.html
coverage.txt

# --- Go / dependencies
vendor/
go.work

# --- Environment & secrets
.env
.env.local
*.csv

# --- Editors / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Database files
*.db
*.sqlite

# --- Logs & temp
*.log
logs/
/tmp/
/var/tmp/
*.pid
*.sock

# --- Misc temp
tmp/
temp/
/backups
chart/

# --- Docker
*.tar
image.tar

# --- Terraform (ignore local state & sensitive vars)
terraform.tfvars
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
deploy/terraform/environments/**/terraform.tfvars
deploy/terraform/environments/**/terraform.tfstate.*
deploy/terraform/environments/**/.terraform/
deploy/terraform/**/tfplan
deploy/terraform/environments/**/.terraform.lock.hcl
deploy/terraform/environments/**/terraform.tfstate
deploy/terraform/environments/**/terraform.tfstate.backup

# --- AWS credentials
.aws/credentials
.aws/config

# --- ecspresso / deployment helpers
deploy/ecspresso/**/test-tfstate.json


# --- Services Binaries and build artifacts
/matching-engine
/gateway
/order-service
/matching-engine
/market-data-service
/simulation-service

# backups
/backups