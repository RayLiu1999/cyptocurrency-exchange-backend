{
  "family": "exchange-staging-monolith",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "{{ tfstate `output.task_execution_role_arn` }}",
  "taskRoleArn": "{{ tfstate `output.task_role_arn` }}",
  "containerDefinitions": [
    {
      "name": "monolith",
      "image": "{{ must_env `ECR_IMAGE` }}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "/exchange/staging/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "/exchange/staging/REDIS_URL"
        }
      ],
      "environment": [
        {
          "name": "KAFKA_BROKERS",
          "value": "redpanda.exchange.internal:9092"
        },
        {
          "name": "GO_ENV",
          "value": "production"
        },
        {
          "name": "KAFKA_ALLOW_AUTO_CREATE",
          "value": "false"
        },
        {
          "name": "PORT",
          "value": "8080"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/exchange/staging/monolith",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "monolith"
        }
      }
    }
  ]
}
